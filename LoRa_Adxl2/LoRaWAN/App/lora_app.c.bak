  PRINT_LORA("On Scheduled Adxl Read Timer Event Read\r\n");
  /* USER CODE END OnTxTimerEvent_1 */
  UTIL_SEQ_SetTask((1 << CFG_SEQ_Task_ScheduledADXL355ReadEvent_Read), CFG_SEQ_Prio_0);

