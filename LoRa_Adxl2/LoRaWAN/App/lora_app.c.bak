	NetworkJoined = LmHandlerJoinStatus( );
	PRINT_LORA("JoinParams: NetworkJoined=%d, Status=%d\r\n", NetworkJoined, joinParams->Status);

	LoRa_Manager_GetState(&state);
	if (state != LORA_IDLE) {
		StartTxTimer();
	}
  /* USER CODE END OnJoinRequest_1 */
}

